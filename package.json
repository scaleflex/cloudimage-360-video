{
  "name": "@cloudimage/360-video",
  "version": "1.4.0",
  "description": "Interactive 360° (equirectangular) video player on Three.js with custom controls, gyroscope, fullscreen, accessibility and React wrapper",
  "license": "MIT",
  "author": "Scaleflex",
  "main": "dist/360-video.cjs.js",
  "module": "dist/360-video.esm.js",
  "unpkg": "dist/360-video.min.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/360-video.esm.js",
      "require": "./dist/360-video.cjs.js"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js",
      "require": "./dist/define.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./filerobot": {
      "types": "./dist/filerobot/index.d.ts",
      "import": "./dist/filerobot/index.js",
      "require": "./dist/filerobot/index.cjs"
    },
    "./css": "./dist/style.css"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/projection/equirectangular.*",
    "**/projection/fisheye.*",
    "src/define.ts",
    "**/define.*"
  ],
  "scripts": {
    "dev": "vite --config config/vite.demo.config.ts",
    "dev:react": "vite --config config/vite.react-demo.config.ts",
    "sandbox": "vite --config sandbox/vite.config.ts",
    "build": "npm run build:bundle && npm run build:define && npm run build:cdn && npm run build:react && npm run build:filerobot && node scripts/verify-bundle.mjs",
    "build:bundle": "vite build --config config/vite.config.ts",
    "build:define": "vite build --config config/vite.define.config.ts",
    "build:cdn": "vite build --config config/vite.cdn.config.ts",
    "build:react": "vite build --config config/vite.react.config.ts",
    "build:filerobot": "vite build --config config/vite.filerobot.config.ts",
    "build:demo": "vite build --config config/vite.demo.config.ts",
    "build:react-demo": "vite build --config config/vite.react-demo.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/ --ext .ts,.tsx",
    "release": "node scripts/release-cdn.mjs plugin",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "dashjs": ">=4.0.0",
    "hls.js": ">=1.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "hls.js": {
      "optional": true
    },
    "dashjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dashjs": "^4.7.4",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "hls.js": "^1.5.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "360",
    "video",
    "player",
    "equirectangular",
    "panorama",
    "vr",
    "webxr",
    "three.js",
    "webgl",
    "cloudimage",
    "scaleflex",
    "react",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/scaleflex/cloudimage-360-video.git"
  },
  "bugs": {
    "url": "https://github.com/scaleflex/cloudimage-360-video/issues"
  },
  "homepage": "https://github.com/scaleflex/cloudimage-360-video#readme"
}
