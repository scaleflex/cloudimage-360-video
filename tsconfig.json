{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@scaleflex/360-video": ["src/index.ts"]
    },
    "outDir": "dist",
    "declarationDir": "dist",
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*", "tests/**/*", "demo/**/*"],
  "exclude": ["node_modules", "dist", "dist-demo", "dist-react-demo"]
}
